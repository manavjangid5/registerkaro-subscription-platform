{
  "name": "registerkaro-subscription-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade subscription billing platform",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "pnpm --filter @registerkaro/shared build && pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @registerkaro/web dev",
    "dev:api": "pnpm --filter @registerkaro/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@registerkaro/eslint-config": "workspace:*",
    "@rolldown/binding-win32-x64-msvc": "^1.1.4",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "typescript": "^5.8.3"
  }
}
